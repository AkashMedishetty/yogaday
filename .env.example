# --- Database ---
# Leave DATABASE_URL UNSET for local development — the app uses an in-process
# Postgres (PGlite) persisted to ./.pglite-data, so it works with zero setup.
#
# For production on Vercel, create a Neon database and paste its connection
# string here (Vercel → Storage → Neon will inject this automatically):
# DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"

# --- Admin panel ---
# Password to access /admin. CHANGE THIS before deploying.
ADMIN_PASSWORD="yoga2026"
# Optional: secret used to sign the admin session cookie. Set any long random
# string in production. If unset, it is derived from ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=""
